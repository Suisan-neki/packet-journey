{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dashboard",
  "version": "0.1.0",
  "identifier": "dev.xdphello.dashboard",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "XDP Sentinel — eBPF Live Dashboard",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
